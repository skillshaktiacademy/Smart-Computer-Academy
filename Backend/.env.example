# Server Configuration
PORT=5000
# Set NODE_ENV=production on the deployed host. In production the auth cookies
# become cross-site (secure + sameSite=none), which REQUIRES the backend to be
# served over HTTPS.
NODE_ENV=development
# In production set BOTH of these to your deployed FRONTEND origin, e.g.
#   CLIENT_URL=https://www.smartcomputeracademy.in
#   CORS_ORIGIN=https://www.smartcomputeracademy.in
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Database
# The database name is appended in code from DB_NAME (src/constants.js),
# so do NOT include it in the URI. Password special chars must be URL-encoded
# (e.g. @ -> %40).
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net

# Authentication (JWT)
# Generate a strong, UNIQUE value for each (use DISTINCT secrets per environment):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ACCESS_TOKEN_SECRET=your_super_secret_access_key_123456
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key_123456
RESET_PASSWORD_SECRET=your_super_secret_reset_key_123456
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Nodemailer/SMTP)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Smart Computer Academy <noreply@smartcomputeracademy.com>"

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
